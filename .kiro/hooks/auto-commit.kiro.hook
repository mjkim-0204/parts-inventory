{
  "name": "Auto Commit on Agent Stop",
  "version": "1.0.0",
  "description": "에이전트 작업이 끝나면 변경사항이 있을 경우 자동으로 git add + commit을 실행합니다.",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git diff --cached --quiet || git commit -m \"auto: 에이전트 작업 완료\""
  }
}
